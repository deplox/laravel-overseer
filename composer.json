{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "deplox/laravel-overseer",
    "type": "library",
    "description": "Laravel application container inspector.",
    "license": "MIT",
    "authors": [
        {
            "name": "Jona Goldman",
            "email": "jonagoldman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Deplox\\Overseer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deplox\\Overseer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Deplox\\Overseer\\OverseerServiceProvider"
            ],
            "aliases": {
                "Overseer": "Deplox\\Overseer\\Facades\\Overseer"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
